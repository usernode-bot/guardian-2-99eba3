{
  "name": "Guardian",
  "secrets": [
    {
      "key": "ENABLE_DEMO_MODE",
      "description": "Enable demo mode in this environment (bypasses wallet confirmation, creates fake blockchain transactions). Defaults to staging environment behavior.",
      "required": false,
      "private": false,
      "default": "false"
    }
  ],
  "tests": [
    { "name": "Home loads", "path": "/", "expectSelector": "#conversationsView" },
    { "name": "Chat thread loads", "path": "/", "expectSelector": "#messageList" },
    { "name": "Discover contacts via sidebar", "path": "/", "expectSelector": "#contactsView" },
    { "name": "Sidebar toggles", "path": "/", "expectSelector": "#sidebar" },
    { "name": "Share contact modal works", "path": "/", "expectSelector": "#shareContactModal" },
    { "name": "Settings panel opens", "path": "/", "expectSelector": "#settingsPanel" },
    { "name": "Network dropdown in settings", "path": "/", "expectSelector": "#networkSelect" },
    { "name": "Network Status section in settings", "path": "/", "expectSelector": "#networkAccordion" },
    { "name": "Profile Guardian's tab loads", "path": "/", "expectSelector": "#profileTabGuardians" },
    { "name": "Feed view renders", "path": "/", "expectSelector": "#feedView" },
    { "name": "World Cup post appears in feed", "path": "/", "expectText": "World Cup 2026" }
  ]
}
