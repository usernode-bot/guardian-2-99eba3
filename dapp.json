{
  "name": "Guardian",
  "secrets": [
    {
      "key": "DATABASE_URL",
      "description": "PostgreSQL connection string for Guardian's database. Format: postgresql://user:password@host:port/database. Required for persistent storage of users, messages, and channels.",
      "required": false,
      "private": true,
      "staging_default": "postgresql://localhost/guardian_staging"
    },
    {
      "key": "NODE_RPC_URL",
      "description": "Usernode blockchain RPC endpoint for transaction submission. Platform provides in-network default; override for custom endpoints. Example: http://usernode-node:3000 (production) or http://usernode-node:3001 (staging).",
      "required": false,
      "private": false,
      "default": "http://usernode-node:3000"
    }
  ],
  "tests": [
    {
      "name": "Home loads",
      "path": "/",
      "expectSelector": "#conversationsView"
    },
    {
      "name": "Chat thread loads",
      "path": "/",
      "expectSelector": "#messageList"
    },
    {
      "name": "Discover contacts via sidebar",
      "path": "/",
      "expectSelector": "#contactsView"
    },
    {
      "name": "Sidebar toggles",
      "path": "/",
      "expectSelector": "#sidebar"
    },
    {
      "name": "Share contact modal works",
      "path": "/",
      "expectSelector": "#shareContactModal"
    },
    {
      "name": "Settings panel opens",
      "path": "/",
      "expectSelector": "#settingsPanel"
    },
    {
      "name": "Profile Guardian's tab loads",
      "path": "/",
      "expectSelector": "#profileTabGuardians"
    }
  ],
  "visibility": {
    "build": "private",
    "view": "public"
  }
}
