{
  "name": "Guardian",
  "secrets": [
    {
      "key": "DATABASE_URL",
      "description": "PostgreSQL connection string for Guardian's database. Format: postgresql://user:password@host:port/database. Required for persistent storage of users, messages, and channels.",
      "required": false,
      "private": true,
      "staging_default": "postgresql://localhost/guardian_staging"
    },
    {
      "key": "APP_PUBKEY",
      "description": "Guardian app's ED25519 public key address (ut1...) for blockchain transactions. Used for transaction signing and app identification on Usernode testnet.",
      "required": true,
      "private": false,
      "default": "ut1Fww7onqF9LsRSb6d6BozgQWtjNYqQJghYxXmBc8foncb"
    },
    {
      "key": "APP_SECRET_KEY",
      "description": "Guardian app's ED25519 private key seed for cryptographic signing of transaction memos on Usernode blockchain. 64 hex characters. Encrypted at rest.",
      "required": true,
      "private": true,
      "staging_default": "guardian_sk_mqudwes5_ae613cf56214808e"
    },
    {
      "key": "NODE_RPC_URL",
      "description": "Usernode blockchain RPC endpoint for transaction submission. Platform provides in-network default; override for custom endpoints.",
      "required": false,
      "private": false,
      "default": "http://usernode-node:3000"
    }
  ],
  "tests": [
    {
      "name": "Home loads",
      "path": "/",
      "expectSelector": "#conversationsView"
    },
    {
      "name": "Chat thread loads",
      "path": "/",
      "expectSelector": "#messageList"
    },
    {
      "name": "Discover contacts via sidebar",
      "path": "/",
      "expectSelector": "#contactsView"
    },
    {
      "name": "Sidebar toggles",
      "path": "/",
      "expectSelector": "#sidebar"
    },
    {
      "name": "Share contact modal works",
      "path": "/",
      "expectSelector": "#shareContactModal"
    },
    {
      "name": "Settings panel opens",
      "path": "/",
      "expectSelector": "#settingsPanel"
    },
    {
      "name": "Network dropdown in settings",
      "path": "/",
      "expectSelector": "#networkSelect"
    },
    {
      "name": "Network Status section in settings",
      "path": "/",
      "expectSelector": "#networkAccordion"
    },
    {
      "name": "Profile Guardian's tab loads",
      "path": "/",
      "expectSelector": "#profileTabGuardians"
    },
    {
      "name": "Channel posts render",
      "path": "/",
      "expectSelector": "#feedContentWrapper"
    },
    {
      "name": "Post menu button visible (if user is post author/owner)",
      "path": "/",
      "expectSelector": "button:has-text('⋮')"
    }
  ],
  "visibility": {
    "build": "private",
    "view": "public"
  }
}
